@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(
    KPim6EventViews
    "@EVENTVIEW_LIB_VERSION@"
)
find_dependency(
    KPim6CalendarSupport
    "@CALENDARSUPPORT_LIB_VERSION@"
)
find_dependency(
    KPim6CalendarUtils
    "@CALENDARUTILS_LIB_VERSION@"
)
find_dependency(
    KF6CalendarCore
    "@KF_MIN_VERSION@"
)
if(@KF6Mime_FOUND@)
    find_dependency(
        KF6Mime
        "@KF_MIN_VERSION@"
    )
else()
    find_dependency(
        KPim6Mime
        "@KPIM_MIME_VERSION@"
    )
    if(NOT TARGET KF6::Mime)
        add_library(KF6::Mime ALIAS KPim6::Mime)
    endif()
endif()
find_dependency(
    KPim6AkonadiMime
    "@AKONADI_MIMELIB_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KPim6IncidenceEditorTargets.cmake")
